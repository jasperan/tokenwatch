# TokenWatch Configuration

# Network binding
TOKENWATCH_HOST=127.0.0.1
TOKENWATCH_PROXY_PORT=8877
TOKENWATCH_DASHBOARD_PORT=8878

# Oracle Database
TOKENWATCH_ORACLE_DSN=localhost:1521/FREEPDB1
TOKENWATCH_ORACLE_USER=TOKENWATCH
TOKENWATCH_ORACLE_PASSWORD=YOUR_TOKENWATCH_DB_PASSWORD

# Upstream API URLs
TOKENWATCH_ANTHROPIC_URL=https://api.anthropic.com
TOKENWATCH_OPENAI_URL=https://api.z.ai

# Request handling
TOKENWATCH_CONNECT_TIMEOUT=10
TOKENWATCH_OVERALL_TIMEOUT=300

# Cache and replay
TOKENWATCH_CACHE_ENABLED=false
TOKENWATCH_CACHE_TTL=86400
TOKENWATCH_CACHE_SIMILARITY_THRESHOLD=0.05
TOKENWATCH_STORE_PROMPTS=false
TOKENWATCH_REDACT_STORED_PROMPTS=true
TOKENWATCH_PROMPT_RETENTION_DAYS=30

# Budgets
TOKENWATCH_BUDGET_ENABLED=true

# OpenTelemetry
TOKENWATCH_OTEL_ENABLED=false
TOKENWATCH_OTEL_ENDPOINT=http://localhost:4317
TOKENWATCH_OTEL_SERVICE_NAME=tokenwatch
